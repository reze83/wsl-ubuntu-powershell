# Alles andere: Git entscheidet
*       text=auto

# Bash-Scripts: immer LF
*.sh    text eol=lf

# PowerShell-Scripts: CRLF fuer Windows-Kompatibilitaet
# UTF-8 BOM wird per CI geprueft.
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Batch-Scripts: CRLF fuer Windows
*.cmd   text eol=crlf

# Markdown: LF
*.md    text eol=lf
